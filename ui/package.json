{
  "name": "thevault-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "start": "echo \"UI start placeholder\" && exit 0",
    "llm:test": "tsx server/bin/llm-test.ts",
    "process-inbox": "node src/server/process_inbox.js",
    "dev": "npm --prefix ui run dev",
    "dev:mocks": "VITE_USE_MOCKS=1 VITE_LLM_BASE=http://localhost:5173 VITE_RAG_BASE=http://localhost:5173 vite --config ui/vite.config.ts",
    "build:ui": "vite build --config ui/vite.config.ts",
    "lint": "eslint -c ui/eslint.config.js ui",
    "typecheck": "tsc -p ui",
    "prepreview": "npm run build:ui",
    "preview": "vite preview --config ui/vite.config.ts",
    "serve:prod": "npm run build:ui && serve -s ui/dist -l 4173",
    "test": "vitest run --config ui/vite.config.ts",
    "rag": "uvicorn System.Scripts.RAG.rag.server:app --host 127.0.0.1 --port 5055 --reload",
    "llm": "uvicorn System.Scripts.RAG.llm.server:app --host 127.0.0.1 --port 5111 --reload",
    "smoke": "npx playwright test || echo 'Playwright not installed, skipping'"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.8.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.48.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/react": "^16.3.0",
    "@types/fs-extra": "^11.0.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "express": "^4.21.2",
    "fs-extra": "^11.3.1",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^2.1.4",
    "yaml": "^2.8.1"
  }
}
